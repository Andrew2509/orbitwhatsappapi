{
  "openapi": "3.0.0",
  "info": {
    "title": "Orbit WhatsApp API (Fixed)",
    "description": "API khusus untuk pengelolaan pesan WhatsApp dan perangkat tanpa rute autentikasi.",
    "version": "1.1.0"
  },
  "servers": [
    {
      "url": "https://orbit-whatsapp-api.vercel.app/api",
      "description": "Production Server"
    },
    {
      "url": "http://localhost:8000/api",
      "description": "Local Development"
    }
  ],
  "paths": {
    "/v1/messages/send": {
      "post": {
        "tags": [
          "WhatsApp Messages"
        ],
        "summary": "Send Message/Media",
        "description": "Mengirim pesan teks atau media via WhatsApp.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["to", "message"],
                "properties": {
                  "to": {
                    "type": "string",
                    "description": "Nomor WhatsApp tujuan dengan kode negara",
                    "example": "628123456789"
                  },
                  "message": {
                    "type": "string",
                    "description": "Isi pesan teks",
                    "example": "Halo! Ini adalah pesan testing dari Orbit API. 🚀"
                  },
                  "file": {
                    "type": "string",
                    "format": "url",
                    "description": "URL publik file/gambar (opsional)",
                    "example": "https://orbit-whatsapp-api.vercel.app/Image/logo-wa-api-black.png"
                  },
                  "device_id": {
                    "type": "integer",
                    "description": "ID Device spesifik (opsional)",
                    "example": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message queued/sent"
          }
        }
      }
    },
    "/v1/messages": {
      "get": {
        "tags": [
          "WhatsApp Messages"
        ],
        "summary": "List Messages",
        "description": "Melihat daftar pesan yang telah dikirim.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "description": "Jumlah data per halaman",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Nomor halaman",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success list of messages"
          }
        }
      }
    },
    "/v1/messages/{id}/status": {
      "get": {
        "tags": [
          "WhatsApp Messages"
        ],
        "summary": "Get Message Status",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID Pesan (Message External ID)",
            "schema": {
              "type": "string",
              "example": "MSG-72-20240314"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Message delivery details"
          }
        }
      }
    },
    "/v1/devices": {
      "get": {
        "tags": [
          "Devices"
        ],
        "summary": "List Connected Devices",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Connected WhatsApp devices"
          }
        }
      }
    },
    "/v1/devices/{id}": {
      "get": {
        "tags": [
          "Devices"
        ],
        "summary": "Get Device Detail",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID Device",
            "schema": {
              "type": "integer",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Device details"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
